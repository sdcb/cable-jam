{
  "version": 3,
  "configurePresets": [
    {
      "name": "vs2026-release",
      "displayName": "Visual Studio 2026 x64 Release (Ninja)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-vs2026",
      "environment": {
        "VSLANG": "1033"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_POLICY_VERSION_MINIMUM": "3.5",
        "CABLE_JAM_BUILD_TESTS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "vs2026-release",
      "configurePreset": "vs2026-release",
      "configuration": "Release",
      "environment": {
        "VSLANG": "1033"
      }
    }
  ],
  "testPresets": [
    {
      "name": "vs2026-release",
      "configurePreset": "vs2026-release",
      "configuration": "Release",
      "environment": {
        "VSLANG": "1033"
      }
    }
  ]
}
